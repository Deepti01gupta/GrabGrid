# GrabGrid Frontend Environment Variables
# Copy this file to .env and fill in the values

# ==========================================
# API CONFIGURATION
# ==========================================
# Backend API URL where the Express server is running
# Development: http://localhost:5000/api
# Production: https://grabgrid-api.onrender.com/api
REACT_APP_API_URL=http://localhost:5000/api

# ==========================================
# REACT CONFIGURATION
# ==========================================
# Don't automatically open browser on npm start
BROWSER=none

# Port to run the development server on
PORT=3000

# ==========================================
# PRODUCTION EXAMPLE (DO NOT USE DIRECTLY)
# ==========================================
# REACT_APP_API_URL=https://grabgrid-api.onrender.com/api
# BROWSER=none
# PORT=3000
