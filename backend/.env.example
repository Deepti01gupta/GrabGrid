# GrabGrid Backend Environment Variables
# Copy this file to .env and fill in the values

# ==========================================
# SERVER CONFIGURATION
# ==========================================
# Port the Express server will run on
PORT=5000

# Environment: development, staging, production
NODE_ENV=development

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# For Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/grabgrid

# For MongoDB Atlas (Cloud):
# Update with your actual cluster name and credentials
# Format: mongodb+srv://username:password@cluster.mongodb.net/databasename
MONGODB_URI=mongodb://localhost:27017/grabgrid

# ==========================================
# JWT AUTHENTICATION
# ==========================================
# Secret key for signing JWT tokens
# IMPORTANT: Use a strong random key in production
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 characters recommended
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# Token expiration time
JWT_EXPIRE=7d

# ==========================================
# CORS CONFIGURATION
# ==========================================
# Allow requests from this origin (frontend URL)
# Development: http://localhost:3000
# Production: https://yourdomain.vercel.app
CORS_ORIGIN=http://localhost:3000

# ==========================================
# PRODUCTION EXAMPLE (DO NOT USE DIRECTLY)
# ==========================================
# PORT=5000
# NODE_ENV=production
# MONGODB_URI=mongodb+srv://grabgrid_user:password@cluster.mongodb.net/grabgrid
# JWT_SECRET=your_generated_32_char_secret_key_here
# JWT_EXPIRE=7d
# CORS_ORIGIN=https://grabgrid.vercel.app
